#include <stdio.h>
#include <stdlib.h>
#define MAX 100
struct Queue {
    int data;
    int priority;
};

struct Queue pqueue[MAX];
int front = -1, rear = -1;

int isFull() {
    return rear == MAX - 1;
}

int isEmpty() {
    return front == -1;
}

void enqueue(int data, int priority) {
    if (isFull()) {
        printf("Queue Overflow!!\n");
        return;
    }
    rear++;
    pqueue[rear].data = data;
    pqueue[rear].priority = priority;
    if (front == -1) {
        front = 0;
    }
    printf("Element Inserted!!!!\n");
}

int gethighestPriority() {
    int max = pqueue[front].priority, index = front;
    for (int i = front + 1; i <= rear; i++) {
        if (pqueue[i].priority > max) {
            max = pqueue[i].priority;
            index = i;
        }
    }
    return index;
}

int dequeue() {
    if (isEmpty()) {
        printf("Queue Underflow!!!\n");
        return -1;
    } else if (front == rear) {
        int val = pqueue[front].data;
        front = rear = -1;
        return val;
    }
    int idx = gethighestPriority();
    int val = pqueue[idx].data;
    for (int i = idx; i < rear; i++) {
        pqueue[i] = pqueue[i + 1];
    }
    rear--;
    return val;
}

int peek() {
    if (isEmpty()) {
        printf("Queue is Empty!!!\n");
        return -1;
    }
    int idx = gethighestPriority();
    return pqueue[idx].data;
}

void display() {
    if (isEmpty()) {                    
        printf("Queue is Empty!!!\n");
        return;
    }
    for (int i = front; i <= rear; i++) {
        printf("Priority: %d --> Value: %d\n", pqueue[i].priority, pqueue[i].data);
    }
}

int main() {
    int choice, value, priority;
    while (1) {
        printf("\n1. Enqueue\n");
        printf("2. Dequeue\n");
        printf("3. Peek\n");
        printf("4. Display Queue\n");
        printf("5. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter Value: ");
                scanf("%d", &value);
                printf("Enter Priority: ");
                scanf("%d", &priority);
                enqueue(value, priority);
                break;

            case 2:
                value = dequeue();
                if (value != -1)
                    printf("%d Dequeued from priority queue\n", value);
                break;

            case 3:
                value = peek();
                if (value != -1)
                    printf("Highest priority element: %d\n", value);
                break;

            case 4:
                display();
                break;

            case 5:
                exit(0);

            default:
                printf("\nInvalid choice\n");
        }
    }
    return 0;
}
