#include <stdio.h>
int partition(int *arr, int start, int end){
    int idx = start-1, pivat = arr[end];
    for(int j = start; j < end; j++){
        if(arr[j] <= pivat){
            idx++;
            int temp = arr[j];
            arr[j] = arr[idx];
            arr[idx] = temp;
        }
    }
    idx++;
    int temp = arr[end];
    arr[end] = arr[idx];
    arr[idx] = temp;
    return idx;
}
void QuickSort(int *arr, int start, int end){
    if(start < end){
        int pivat = partition(arr, start, end);
        QuickSort(arr, start, pivat - 1);
        QuickSort(arr, pivat + 1, end);
    }
}
int main(){
    int n;
    printf("Enter array size: ");
    scanf("%d", &n);
    int arr[n];
    printf("Enter array elements: ");
    for(int i = 0; i < n; i++)
        scanf("%d", &arr[i]);
    QuickSort(arr, 0, n-1);
        printf("After sorting array elements: ");
        for(int i = 0; i < n; i++){
            printf("%d ", arr[i]);
        }
    return 0;
}
