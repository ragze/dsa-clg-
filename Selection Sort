#include <stdio.h>
int main(){
    int n;
    printf("Enter array size: ");
    scanf("%d", &n);
    int arr[n];
    printf("Enter array elements:");
    for(int i = 0; i < n; i++){
        scanf("%d", &arr[i]);
    }
    //Selection search logic
    for(int i = 0; i < n-1; i++){
        int minIdx = i;
        for(int j = i+1; j<n; j++){
            if(arr[j] < arr[minIdx]){
                minIdx = j;
            }
        }
        if(minIdx != i){
            int temp = arr[minIdx];
            arr[minIdx] = arr[i];
            arr[i] = temp;
        }
        
    }
    printf("After sorting elements are: \n");
    for(int i = 0; i<n; i++){
        printf("%d ", arr[i]);
    }
    return 0;
}
