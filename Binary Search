#include <stdio.h>
int main(){
    int n;
    printf("Enter array size: ");
    scanf("%d", &n);
    int arr[n];
    printf("Enter array elements:");
    for(int i = 0; i < n; i++){
        scanf("%d", &arr[i]);
    }
    int val;
    printf("Enter searching element: ");
    scanf("%d", &val);
    //Binary search logic
    int startIdx = 0, endIdx = n-1;
    while(startIdx <= endIdx){
        int mid = startIdx + (endIdx - startIdx)/2;
        if(val == arr[mid]){
            printf("Found !!!\n");
            return 0;
        }
        else if(val < arr[mid]){
            endIdx = mid - 1;
        }
        else{
            startIdx = mid + 1;
        }
    }
    printf("Not Found !!!\n");
    return 0;
}
